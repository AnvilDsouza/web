  <style>
    :root{
      --bg:#0b1020;
      --bg-soft:#111831;
      --card:#121a35;
      --card-2:#162043;
      --text:#f5f7ff;
      --muted:#b8c0e0;
      --line:rgba(255,255,255,.08);
      --accent:#ffb703;
      --accent-2:#ff6b6b;
      --success:#25d366;
      --shadow:0 18px 50px rgba(0,0,0,.25);
      --radius:22px;
      --max:1180px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(255,183,3,.14), transparent 28%),
        radial-gradient(circle at top right, rgba(255,107,107,.12), transparent 26%),
        linear-gradient(180deg, #070b16 0%, #0b1020 45%, #09101d 100%);
      color:var(--text);
      line-height:1.5;
    }

    a{color:inherit; text-decoration:none}
    img{max-width:100%; display:block}
    .container{max-width:var(--max); margin:0 auto; padding:0 20px}
    .section{padding:84px 0}
    .eyebrow{
      display:inline-flex; gap:8px; align-items:center;
      padding:8px 14px; border:1px solid var(--line); border-radius:999px;
      color:var(--accent); background:rgba(255,183,3,.07);
      font-size:.9rem; letter-spacing:.02em;
    }
	.add-note{visibility:hidden}
    .eyebrow .dot{width:8px;height:8px;border-radius:50%;background:var(--accent)}
    h1,h2,h3,p{margin:0}
    h1{
      font-size:clamp(2.4rem, 5vw, 4.9rem);
      line-height:1.03;
      letter-spacing:-0.03em;
      margin-top:18px;
    }
    h2{
      font-size:clamp(1.8rem, 3vw, 2.8rem);
      line-height:1.12;
      letter-spacing:-0.02em;
      margin-bottom:14px;
    }
    .sub{
      color:var(--muted);
      max-width:720px;
      font-size:1.05rem;
    }

    /* Header */
    .topbar{
      position:sticky; top:0; z-index:1000;
      backdrop-filter: blur(16px);
      background:rgba(7,11,22,.72);
      border-bottom:1px solid rgba(255,255,255,.06);
    }
    .nav{
      display:flex; align-items:center; justify-content:space-between;
      gap:14px; min-height:76px;
    }
    .brand{
      display:flex; align-items:center; gap:12px; font-weight:800;
      letter-spacing:.01em;
    }
    .brand-badge{
      width:42px;height:42px;border-radius:14px;
      background:linear-gradient(135deg, var(--accent), var(--accent-2));
      display:grid;place-items:center;color:#111;font-weight:900;
      box-shadow:0 10px 30px rgba(255,183,3,.28);
    }
    .nav-links{
      display:flex; align-items:center; gap:18px; color:var(--muted); font-weight:600;
    }
    .nav-links a:hover{color:var(--text)}
    .nav-cta{display:flex; align-items:center; gap:10px}
    .btn{
      display:inline-flex; align-items:center; justify-content:center;
      gap:10px; padding:13px 18px; border-radius:14px;
      border:1px solid transparent; font-weight:800;
      transition:.2s ease; cursor:pointer; white-space:nowrap;
    }
    .btn:hover{transform:translateY(-1px)}
    .btn-primary{
      background:linear-gradient(135deg, var(--accent), #ffd166);
      color:#1b1300;
      box-shadow:0 12px 30px rgba(255,183,3,.20);
    }
    .btn-secondary{
      background:transparent; border-color:var(--line); color:var(--text);
    }
    .menu-toggle{
      display:none;
      width:46px;height:46px;border-radius:14px;
      border:1px solid var(--line); background:rgba(255,255,255,.02);
      color:var(--text);
    }

    /* Hero */
    .hero{
      padding:52px 0 28px;
      position:relative;
      overflow:hidden;
    }
    .hero-grid{
      display:grid; grid-template-columns: 1.15fr .85fr; gap:30px;
      align-items:stretch;
    }
    .hero-copy{
      padding:36px 0 18px;
    }
    .hero-actions{
      display:flex; flex-wrap:wrap; gap:14px; margin-top:28px;
    }
    .hero-metrics{
      display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-top:28px;
    }
    .metric{
      padding:18px; border:1px solid var(--line); border-radius:18px;
      background:rgba(255,255,255,.02);
    }
    .metric strong{display:block; font-size:1.2rem}
    .metric span{color:var(--muted); font-size:.92rem}

    .hero-card{
      border:1px solid var(--line);
      border-radius:28px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02)),
        url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1200&q=80') center/cover;
      min-height:620px;
      box-shadow:var(--shadow);
      position:relative;
      overflow:hidden;
      display:flex;
      align-items:flex-end;
    }
    .hero-overlay{
      width:100%;
      padding:22px;
      background:linear-gradient(180deg, transparent 0%, rgba(5,7,12,.22) 12%, rgba(5,7,12,.85) 100%);
    }
    .card-badges{
      display:flex; flex-wrap:wrap; gap:10px; margin-bottom:14px;
    }
    .badge{
      padding:8px 12px;border-radius:999px;
      background:rgba(255,255,255,.1);
      border:1px solid rgba(255,255,255,.08);
      color:#fff; font-size:.88rem;
      backdrop-filter: blur(6px);
    }
    .menu-preview{
      display:grid; gap:12px;
      margin-top:18px;
    }
    .preview-item{
      display:flex; align-items:center; justify-content:space-between; gap:16px;
      padding:14px 16px; border-radius:18px;
      background:rgba(11,16,32,.82);
      border:1px solid rgba(255,255,255,.08);
    }
    .preview-item small{display:block;color:var(--muted)}
    .preview-item .price{color:var(--accent); font-weight:900}

    /* Cards */
    .grid-3{display:grid; grid-template-columns:repeat(3,1fr); gap:18px}
    .grid-2{display:grid; grid-template-columns:repeat(2,1fr); gap:18px}
    .card{
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
      border:1px solid var(--line);
      border-radius:var(--radius);
      padding:22px;
      box-shadow:var(--shadow);
    }
    .card h3{font-size:1.05rem;margin-bottom:10px}
    .card p, .muted{color:var(--muted)}
    .icon{
      width:50px;height:50px;border-radius:16px;
      display:grid;place-items:center;
      background:linear-gradient(135deg, rgba(255,183,3,.18), rgba(255,107,107,.14));
      border:1px solid rgba(255,255,255,.08);
      margin-bottom:16px;
      font-size:1.2rem;
    }

    /* Menu */
    .menu-filters{
      display:flex; flex-wrap:wrap; gap:10px; margin:22px 0 26px;
    }
    .pill{
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      color:var(--text);
      padding:10px 14px; border-radius:999px;
      cursor:pointer; font-weight:700;
    }
    .pill.active{
      background:linear-gradient(135deg, var(--accent), #ffd166);
      color:#1b1300; border-color:transparent;
    }
    .menu-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:16px}
    .menu-item{
      padding:18px; border-radius:22px; background:rgba(255,255,255,.03);
      border:1px solid var(--line);
      display:flex; flex-direction:column; gap:14px;
    }
    .dish-top{display:flex; justify-content:space-between; gap:12px; align-items:flex-start}
    .dish-top h3{margin:0}
    .dish-meta{color:var(--muted); font-size:.92rem}
    .dish-price{font-weight:900; color:var(--accent); font-size:1.1rem}
    .dish-image{
      aspect-ratio: 16/10;
      border-radius:18px;
      background:#10162d center/cover no-repeat;
      border:1px solid rgba(255,255,255,.06);
    }
    .menu-actions{display:flex; gap:10px; flex-wrap:wrap}

    .small-btn{
      padding:11px 14px; border-radius:12px;
      font-weight:800; font-size:.94rem;
      border:1px solid var(--line); color:var(--text);
      background:rgba(255,255,255,.03);
    }
    .small-btn.whatsapp{
      background:linear-gradient(135deg, rgba(37,211,102,.96), rgba(37,211,102,.78));
      color:#07210f; border-color:transparent;
    }

    /* Story / About */
    .timeline{
      display:grid; gap:14px;
    }
    .step{
      display:flex; gap:14px; padding:18px; border-radius:18px;
      border:1px solid var(--line); background:rgba(255,255,255,.03);
    }
    .step .num{
      width:36px;height:36px;border-radius:12px;
      background:linear-gradient(135deg, var(--accent), #ffd166);
      color:#1b1300; display:grid; place-items:center; font-weight:900;
      flex:0 0 auto;
    }

    /* Testimonials */
    .review{
      display:flex; flex-direction:column; gap:12px;
      min-height:180px;
    }
    .stars{color:var(--accent); letter-spacing:1px}
    .reviewer{
      display:flex; align-items:center; gap:12px; margin-top:auto;
    }
    .avatar{
      width:44px;height:44px;border-radius:50%;
      background:linear-gradient(135deg, var(--accent-2), var(--accent));
    }

    /* FAQ */
    details{
      border:1px solid var(--line);
      border-radius:18px;
      padding:16px 18px;
      background:rgba(255,255,255,.03);
    }
    details + details{margin-top:12px}
    summary{
      cursor:pointer; font-weight:800;
      list-style:none;
    }
    summary::-webkit-details-marker{display:none}

    /* CTA */
    .cta{
      background:
        linear-gradient(135deg, rgba(255,183,3,.16), rgba(255,107,107,.12)),
        linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      border:1px solid rgba(255,255,255,.10);
      border-radius:32px;
      padding:28px;
      box-shadow:var(--shadow);
    }
    .cta-inner{
      display:flex; align-items:center; justify-content:space-between; gap:18px;
    }

    .footer{
      padding:26px 0 40px;
      color:var(--muted);
      border-top:1px solid rgba(255,255,255,.06);
      margin-top:48px;
    }
    .footer-grid{
      display:grid; grid-template-columns:1.4fr .8fr .8fr; gap:20px;
    }

    .sticky-whatsapp{
      position:fixed;
      right:18px; bottom:18px;
      z-index:1200;
      display:flex; align-items:center; gap:10px;
      border-radius:999px;
      background:linear-gradient(135deg, var(--success), #72f0a3);
      color:#053816;
      padding:14px 18px;
      font-weight:900;
      box-shadow:0 16px 38px rgba(37,211,102,.25);
      border:0;
    }
    .floating-analytics{
      position:fixed; left:18px; bottom:18px; z-index:1200;
      background:rgba(10,14,28,.88);
      border:1px solid var(--line);
      color:var(--text);
      padding:12px 14px;
      border-radius:16px;
      max-width:290px;
      box-shadow:var(--shadow);
    }
    .floating-analytics strong{display:block; margin-bottom:4px}
    .floating-analytics span{color:var(--muted); font-size:.9rem}

    .mobile-nav{
      display:none;
      padding:0 20px 16px;
    }
    .mobile-nav a{
      display:block;
      padding:12px 0;
      color:var(--muted);
      border-top:1px solid rgba(255,255,255,.06);
    }

    /* Responsive */
    @media (max-width: 1024px){
      .hero-grid{grid-template-columns:1fr}
      .hero-card{min-height:500px}
      .grid-3, .menu-grid{grid-template-columns:repeat(2,1fr)}
      .footer-grid{grid-template-columns:1fr 1fr}
    }
    @media (max-width: 768px){
      .nav-links, .nav-cta .btn-secondary{display:none}
      .menu-toggle{display:inline-grid;place-items:center}
      .mobile-nav.open{display:block}
      .hero{padding-top:34px}
      .hero-metrics, .grid-3, .grid-2, .menu-grid, .footer-grid{grid-template-columns:1fr}
      .cta-inner{flex-direction:column; align-items:flex-start}
      .section{padding:64px 0}
      .floating-analytics{max-width:240px}
    }
  </style>
</head>

