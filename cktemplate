  <script>
    const menuToggle = document.getElementById('menuToggle');
    const mobileNav = document.getElementById('mobileNav');
    menuToggle?.addEventListener('click', () => mobileNav.classList.toggle('open'));

    // Menu filtering
    const filterButtons = document.querySelectorAll('.pill');
    const items = document.querySelectorAll('.menu-item');

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        filterButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        items.forEach(item => {
          const show = filter === 'all' || item.dataset.category === filter;
          item.style.display = show ? 'flex' : 'none';
        });
      });
    });

    // Track clicks to Google Analytics
    function trackEvent(action, label) {
      if (typeof gtag === 'function') {
        gtag('event', action, {
          event_category: 'engagement',
          event_label: label
        });
      }
    }

    document.querySelectorAll('.track-click').forEach(el => {
      el.addEventListener('click', () => {
        trackEvent('whatsapp_click', el.dataset.item || 'unknown');
      });
    });

    // "Add Note" button opens prefilled WhatsApp with notes prompt
    document.querySelectorAll('.add-note').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.dataset.item || 'item';
        const url = `https://wa.me/918454921895?text=Hi%20I%20want%20to%20order%20${encodeURIComponent(item)}%20with%20some%20customization`;
        trackEvent('add_note_click', item);
        window.open(url, '_blank', 'noopener');
      });
    });
  </script>

